  },
];

const enterpriseStats = [
  { value: "SLA", label: "маршрут, сроки и контрольные точки" },
  { value: "ВЭД", label: "документы и официальный импорт" },
  { value: "FCL/LCL", label: "контейнеры и сборные партии" },
];

const documentItems = [
  "инвойс",
  "упаковочный лист",
  "контрактная часть",
  "описание товара",
  "фото- и видеоотчет",
  "закрывающие документы",
];

const promises = [
  "не называем финальную цену без веса, объема и города получения",
  "не обещаем срок без маршрута, склада и формата оформления",
  "не берем запрещенные к перевозке или ввозу грузы",
  "не подменяем договор перепиской в мессенджере",
];

const trustItems = [
  "товар и количество мест",
  "вес, объем и упаковка",
  "поставщик и условия закупки",
  "фото- и видеоотчет",
  "инвойс и упаковочный лист",
  "маршрут и формат оформления",
  "город получения и ответственное лицо",
  "следующий шаг до оплаты",
];

const routeLanes = [
  {
    from: "Гуанчжоу",
    to: "Москва / Санкт-Петербург",
    label: "авто и ЖД",
    text: "Для регулярных поставок, маркетплейсов, электроники, текстиля и товаров для дома.",
  },
  {
    from: "Иу",
    to: "Регионы РФ",
    label: "сборные грузы",
    text: "Для небольших партий, закупок у нескольких поставщиков и консолидации на складе.",
  },
  {
    from: "Порт / склад",
    to: "Склад клиента",
    label: "контейнер",
    text: "Для объемных партий, оборудования, комплектующих и официального коммерческого импорта.",
  },
];

const process = [
  {
    title: "Разбираем задачу",
    text: "Уточняем товар, объем, вес, город получения, сроки, требования к документам и формат поставки.",
  },
  {
    title: "Проверяем поставщика",
    text: "При необходимости ищем фабрику, сравниваем предложения, проверяем образцы и фиксируем условия закупки.",
  },
  {
    title: "Принимаем груз в Китае",
    text: "Склад в Гуанчжоу или Иу принимает товары, сверяет количество, консолидирует партии и готовит упаковку.",
  },
  {
    title: "Собираем маршрут и документы",
    text: "Подбираем способ доставки, заранее обсуждаем инвойсы, упаковочные листы, оформление и ответственность.",
  },
  {
    title: "Доставляем в Россию",
    text: "Контролируем движение груза, передаем партию в России и помогаем с дальнейшей отправкой по регионам.",
  },
];

const scenarios = [
  {
    title: "Партия для маркетплейса",
    meta: "Иу / Гуанчжоу -> склад РФ",
    steps: ["поставщик найден", "выкуп и приемка", "проверка упаковки", "авто или сборный груз", "передача в РФ"],
  },
  {
    title: "Оборудование или комплектующие",
    meta: "фабрика -> контейнер / ЖД",
    steps: ["сверяем документы", "фиксируем габариты", "выбираем маршрут", "готовим оформление", "контролируем передачу"],
  },
];

const cargoTypes = [
  "товары для Ozon и Wildberries",
  "электроника и техника",
  "одежда, обувь и текстиль",
  "мебель и товары для дома",
  "оборудование и станки",
  "автозапчасти и комплектующие",
  "образцы и малогабаритные партии",
  "контейнерные и сборные грузы",
];

const briefOptions = [
  "поставщик уже найден",
  "нужен поиск фабрики",
  "нужен выкуп товара",
  "нужна проверка качества",
  "нужны документы",
  "нужна доставка по РФ",
];

const faqItems = [
  {
    question: "Какой срок доставки из Китая в Россию?",
    answer:
      "Обычно доставка занимает от 10 до 45 дней. Срок зависит от способа перевозки, города отправления, региона получения, веса, объема и требований к оформлению.",
  },
  {
    question: "Можно ли выкупить товар у поставщика за меня?",
    answer:
      "Да. Вы присылаете ссылку на товар или контакт поставщика, а мы проверяем условия, выкупаем товар, принимаем его на склад в Китае и организуем доставку.",
  },
  {
    question: "Вы занимаетесь таможенным оформлением?",
    answer:
      "Да, для коммерческих партий можно заранее собрать схему поставки с документами и официальным оформлением. Формат зависит от товара, документов поставщика и задачи бизнеса.",
  },
  {
    question: "С какими товарами работает RWSCargo / РВС Карго?",
    answer:
      "Мы доставляем промышленные и потребительские товары: электронику, текстиль, мебель, комплектующие, оборудование, автозапчасти, товары для маркетплейсов и другие разрешенные к ввозу грузы.",
  },
  {
    question: "Есть ли склад в Китае?",
    answer:
      "Да. На старом сайте RWSCargo / РВС Карго указаны склады в Гуанчжоу и Иу: они используются для приемки, консолидации, проверки и подготовки грузов к отправке.",
  },
  {
    question: "Что нужно для расчета доставки?",
    answer:
      "Нужны название товара, ссылка или контакт поставщика, вес и объем, количество мест, город отправления в Китае, город получения в России и желаемые сроки.",
  },
];

const faqGroups = [
  {
    title: "Доставка",
    questions: [faqItems[0], faqItems[5]],
  },
  {
    title: "Закупка и склад",
    questions: [faqItems[1], faqItems[4]],
  },
  {
    title: "Документы",
    questions: [faqItems[2], faqItems[3]],
  },
];

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: brandName,
  alternateName: brandNameRu,
  url: siteUrl,
  email: "info@rwscargo.ru",
  telephone: "+7 921 655-65-60",
  areaServed: ["Россия", "Китай"],
  description: pageDescription,
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Доставка грузов из Китая в Россию",
  provider: {
    "@type": "Organization",
    name: brandName,
    alternateName: brandNameRu,
    url: siteUrl,
  },
  areaServed: ["Россия", "Китай"],
  serviceType: "Международная логистика, импорт из Китая, доставка под ключ",
  description: pageDescription,
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={siteUrl} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#f6f4ef" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:site_name" content="RWSCargo / РВС Карго" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={`${siteUrl}images/hero-logistics-import.png`} />
    <meta name="twitter:card" content="summary_large_image" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="RWSCargo / РВС Карго">
        <strong><span>RWS</span>Cargo</strong>
        <small>РВС Карго</small>
      </a>
      <nav class="nav-links" aria-label="Основная навигация">
        <a href="#services">Услуги</a>
        <a href="#delivery">Доставка</a>
        <a href="#calculator">Калькулятор</a>
        <a href="#process">Процесс</a>
        <a href="#faq">FAQ</a>
        <a href="#contacts">Контакты</a>
      </nav>
      <a class="header-phone" href="tel:+79216556560">+7 (921) 655-65-60</a>
      <a class="header-cta" href="#calculator">Рассчитать поставку</a>
    </header>

    <main>
      <section class="hero">
        <div class="hero-copy">
          <p class="eyebrow">Импорт из Китая для бизнеса</p>
          <h1>Доставка грузов из Китая под ключ и в белую</h1>
          <p class="lead">
            RWSCargo / РВС Карго помогает предпринимателям и компаниям покупать, проверять,
            оформлять и доставлять товары из Китая в Россию. Сначала собираем
            понятную схему поставки, потом везем груз.
          </p>
          <div class="hero-actions">
            <a class="button primary" href="#calculator">Получить расчет</a>
            <a class="button secondary" href="#process">Посмотреть процесс</a>
          </div>
          <div class="hero-badges" aria-label="Ключевые преимущества">
            <span>поиск поставщика</span>
            <span>выкуп товара</span>
            <span>контроль качества</span>
            <span>документы</span>
          </div>
        </div>

        <div class="hero-visual" aria-label="Операционный штаб поставки">
          <img src="/images/hero-logistics-import.png" alt="Грузовик с контейнером и коробками на складе" />
          <div class="photo-brand" aria-hidden="true">
            <strong>RWSCargo</strong>
            <span>РВС Карго</span>
          </div>
          <div class="shipment-panel">
            <div class="panel-top">
              <span>Поставка Китай - Россия</span>
              <strong>в работе</strong>
            </div>
            <dl>
              <div>
                <dt>Поставщик</dt>
                <dd>проверка условий</dd>
              </div>
              <div>
                <dt>Склад</dt>
                <dd>Гуанчжоу / Иу</dd>
              </div>
              <div>
                <dt>Документы</dt>
                <dd>до отправки</dd>
              </div>
              <div>
                <dt>Маршрут</dt>
                <dd>авто, авиа, ЖД, контейнер</dd>
              </div>
            </dl>
          </div>
          <div class="status-card">
            <span>Следующий шаг</span>
            <strong>сверить объем и город получения</strong>
          </div>
        </div>
      </section>

      <section class="metric-strip" aria-label="Факты о RWSCargo / РВС Карго">
        {
          highlights.map((item) => (
            <article>
              <strong>{item.value}</strong>
              <span>{item.label}</span>
            </article>
          ))
        }
      </section>

      <section class="task-section" aria-label="Быстрый выбор задачи">
        <div class="task-intro">
          <p class="eyebrow">С чего начать</p>
          <h2>Выберите задачу, а не услугу из списка</h2>
        </div>
        <div class="task-grid">
          {
            taskCards.map((task) => (
              <a href="#contacts" class="task-card">
                <strong>{task.title}</strong>
                <span>{task.text}</span>
              </a>
            ))
          }
        </div>
      </section>

      <section class="section intro-section">
        <div class="section-kicker">Что изменили в подходе</div>
        <div class="intro-grid">
          <h2>Не просто перевозим коробки. Собираем управляемую поставку.</h2>
          <p>
            Старый сайт RWSCargo / РВС Карго делал акцент на снижении себестоимости,
            маркетплейс-бизнесе и полном цикле работы с Китаем. В новой версии
            этот смысл вынесен вперед: поставщик, закупка, проверка, склад,
            маршрут, документы и передача груза должны быть понятны до оплаты и
            отправки.
          </p>
        </div>
      </section>

      <section class="section services-section" id="services">
        <div class="section-head">
          <p class="eyebrow">Услуги RWSCargo / РВС Карго</p>
          <h2>Все этапы импорта из Китая в одном процессе</h2>
          <p>
            Можно подключить только доставку или собрать поставку под ключ: от
            поиска фабрики и выкупа товара до оформления документов и передачи
            партии в России.
          </p>
        </div>

        <div class="services-grid">
          {
            serviceCards.map((service, index) => (
              <article class={`service-card ${index === 0 ? "service-card-main" : ""}`}>
                <span class="card-number">{String(index + 1).padStart(2, "0")}</span>
                <h3>{service.title}</h3>
                <p>{service.text}</p>
                <ul>
                  {service.points.map((point) => (
                    <li>{point}</li>
