---
import "../styles/global.css";

const siteUrl = "https://rwscargo.ru";
const pageTitle = "Доставка грузов из Китая в Россию в белую - RWSCargo";
const pageDescription =
  "RWSCargo организует доставку коммерческих грузов из Китая в Россию в белую: документы, проверка поставщика, контроль качества, контейнерные и сборные партии для бизнеса.";
const faqItems = [
  {
    question: "Что значит доставка грузов из Китая в белую?",
    answer:
      "Это поставка с документами и понятной схемой оформления для бизнеса: маршрут, инвойсы, контрактная часть, таможенные и закрывающие документы обсуждаются до отправки груза.",
  },
  {
    question: "RWSCargo работает с мелкими заказами или с коммерческими партиями?",
    answer:
      "Основной фокус проекта - коммерческие грузы, регулярные поставки, контейнеры и сборные партии для бизнеса, которому важны документы, контроль и предсказуемость.",
  },
  {
    question: "Можно ли проверить поставщика и товар до отправки?",
    answer:
      "Да. В процесс можно включить проверку поставщика, согласование образцов, контроль упаковки и качества до отправки груза из Китая.",
  },
  {
    question: "Какие грузы можно доставлять из Китая?",
    answer:
      "Оборудование, комплектующие, товары для маркетплейсов, мебель, текстиль, электронику, автотовары, промышленные партии и другие коммерческие грузы после проверки условий перевозки и оформления.",
  },
];

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "RWSCargo",
  url: siteUrl,
  description: pageDescription,
  areaServed: ["RU", "CN"],
  knowsAbout: [
    "доставка грузов из Китая",
    "импорт из Китая для бизнеса",
    "доставка в белую",
    "контейнерные перевозки из Китая",
    "проверка поставщика в Китае",
  ],
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Доставка коммерческих грузов из Китая в Россию в белую",
  provider: {
    "@type": "Organization",
    name: "RWSCargo",
    url: siteUrl,
  },
  areaServed: ["Россия", "Китай"],
  serviceType: "Международная логистика и импорт из Китая",
  description: pageDescription,
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={siteUrl} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#fffaf3" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:site_name" content="RWSCargo" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </head>
  <body>
    <main class="page-shell">
      <header class="site-header" aria-label="Основная навигация">
        <a class="brand" href="/" aria-label="RWSCargo">
          <span>RWS</span>Cargo
        </a>
        <nav class="nav-links">
          <a href="#services">Услуги</a>
          <a href="#directions">Грузы</a>
          <a href="#process">Как работаем</a>
          <a href="#faq">FAQ</a>
          <a href="#contacts">Контакты</a>
        </nav>
        <a class="header-cta" href="#contacts">Рассчитать поставку</a>
      </header>

      <section class="ops-hero">
        <div class="ops-layout">
          <div class="ops-copy">
            <p class="eyebrow">Для бизнеса, который вырос из хаоса</p>
            <h1>Белый импорт из Китая</h1>
            <p class="hero-text">
              Когда партия становится серьёзной, одной переписки уже мало.
              RWSCargo проверяет поставщика, собирает документы, считает
              маршрут и доводит коммерческий груз до России без серых обещаний.
            </p>
            <div class="hero-actions">
              <a class="primary-button" href="#contacts">Разобрать поставку</a>
              <a class="secondary-button" href="#process">Как устроен процесс</a>
            </div>
          </div>

          <div class="ops-visual">
            <div class="route-board" tabindex="0" aria-label="Кадр маршрута поставки">
              <div class="board-grid"></div>
              <div class="board-title">
                <span>не обещание в чате</span>
                <strong>Маршрут. Документы. Груз.</strong>
              </div>
              <div class="cursor-ghost" aria-hidden="true"></div>
              <svg class="route-line" viewBox="0 0 900 520" aria-hidden="true">
                <path
                  d="M86 352 C 230 172, 370 190, 478 286 S 690 414, 812 150"
                  pathLength="1"
                />
              </svg>

              <button class="route-node node-china" type="button" data-stage="supplier" aria-label="Подробнее про проверку поставщика">
                <span>Китай</span>
                <strong>Поставщик</strong>
                <small>проверка, образцы, склад</small>
              </button>
              <button class="route-node node-border" type="button" data-stage="documents" aria-label="Подробнее про документы до отправки">
                <span>До отправки</span>
                <strong>Документы</strong>
                <small>инвойс, контракт, упаковка</small>
              </button>
              <button class="route-node node-russia" type="button" data-stage="handoff" aria-label="Подробнее про передачу груза в России">
                <span>Россия</span>
                <strong>Передача</strong>
                <small>город, склад, ответственное лицо</small>
              </button>

              <div class="cargo-stack" aria-hidden="true">
                <span></span>
                <span></span>
                <span></span>
                <span></span>
              </div>

              <button class="shipment-card" type="button" data-stage="dossier" aria-label="Подробнее про схему поставки">
                <span class="card-kicker">досье поставки</span>
                <strong>Сначала схема. Потом груз.</strong>
                <dl>
                  <div>
                    <dt>Формат</dt>
                    <dd>коммерческая партия</dd>
                  </div>
                  <div>
                    <dt>Оформление</dt>
                    <dd>в белую</dd>
                  </div>
                  <div>
                    <dt>Контроль</dt>
                    <dd>до отправки</dd>
                  </div>
                </dl>
              </button>

              <p class="route-caption">
                Чем крупнее партия, тем дороже ошибка. Поэтому маршрут,
                документы и проверка идут до движения груза, а не после.
              </p>

              <div class="route-detail" aria-live="polite">
                <button class="route-detail-close" type="button" aria-label="Закрыть описание этапа">×</button>
                <article class="detail-copy detail-supplier">
                  <span>Китай</span>
                  <strong>Сначала проверяем сторону, от которой зависит партия.</strong>
                  <p>Уточняем поставщика, склад, образцы, упаковку и риски до оплаты или отправки, чтобы проблема не приехала вместе с грузом.</p>
                </article>
                <article class="detail-copy detail-documents">
                  <span>До отправки</span>
                  <strong>Документы собираются до движения груза.</strong>
                  <p>Обсуждаем схему оформления, инвойс, контрактную часть и требования к партии заранее, а не когда груз уже стоит на маршруте.</p>
                </article>
                <article class="detail-copy detail-handoff">
                  <span>Россия</span>
                  <strong>Передача должна быть понятной для бизнеса.</strong>
                  <p>Фиксируем город, склад, ответственное лицо и формат закрытия поставки, чтобы финальный этап не превращался в поиски груза.</p>
                </article>
                <article class="detail-copy detail-dossier">
                  <span>Досье поставки</span>
                  <strong>Одна партия — одна понятная схема.</strong>
                  <p>Собираем ключевые решения в единый сценарий: что везём, как оформляем, где проверяем и каким маршрутом доставляем.</p>
                </article>
              </div>
            </div>
          </div>
        </div>

      </section>

      <div class="route-start" aria-label="Запуск маршрута поставки">
        <button class="route-start-button" type="button" data-road-start>
          <span></span>
          Показать маршрут поставки
        </button>
      </div>

      <section class="route-road" id="cargo-transition" data-road data-road-choice="none" aria-label="Маршрут поставки">
        <div class="road-layout">
          <div class="road-canvas">
            <svg class="road-svg" viewBox="0 0 900 1160" preserveAspectRatio="none" aria-hidden="true">
              <path
                class="road-bed"
                d="M590 0 C 570 112, 620 214, 552 330 S 492 454, 520 520"
              />
              <path
                class="road-bed road-bed-branch"
                d="M520 520 C 420 650, 318 842, 252 1160"
              />
              <path
                class="road-bed road-bed-branch"
                d="M520 520 C 612 650, 696 842, 706 1160"
              />
              <path
                class="road-marking"
                d="M590 0 C 570 112, 620 214, 552 330 S 492 454, 520 520"
              />
              <path
                class="road-marking road-marking-branch"
                d="M520 520 C 420 650, 318 842, 252 1160"
              />
              <path
                class="road-marking road-marking-branch"
                d="M520 520 C 612 650, 696 842, 706 1160"
              />
              <path
                class="road-shadow"
                d="M590 0 C 570 112, 620 214, 552 330 S 492 454, 520 520"
              />
              <path
                class="road-shadow road-shadow-branch"
                d="M520 520 C 420 650, 318 842, 252 1160"
              />
              <path
                class="road-shadow road-shadow-branch"
                d="M520 520 C 612 650, 696 842, 706 1160"
              />
              <path
                class="road-line road-trunk"
                data-road-trunk
                d="M590 0 C 570 112, 620 214, 552 330 S 492 454, 520 520"
              />
              <path
                class="road-line road-branch road-branch-small"
                data-road-branch-small
                d="M520 520 C 420 650, 318 842, 252 1160"
              />
              <path
                class="road-line road-branch road-branch-big"
                data-road-branch-big
                d="M520 520 C 612 650, 696 842, 706 1160"
              />
              <g class="road-vehicle road-vehicle-truck" aria-hidden="true">
                <rect class="vehicle-trailer" x="-34" y="-7" width="38" height="14" rx="3" />
                <rect class="vehicle-cab" x="4" y="-6" width="17" height="12" rx="3" />
                <rect class="vehicle-window" x="8" y="-3" width="7" height="6" rx="1.5" />
                <animateMotion
                  dur="16s"
                  begin="-3s"
                  repeatCount="indefinite"
                  rotate="auto"
                  path="M590 0 C 570 112, 620 214, 552 330 S 492 454, 520 520 C 612 650, 696 842, 706 1160"
                />
              </g>
              <g class="road-vehicle road-vehicle-car road-vehicle-small" aria-hidden="true">
                <rect class="vehicle-body" x="-16" y="-6" width="32" height="12" rx="6" />
                <rect class="vehicle-roof" x="-5" y="-4" width="10" height="8" rx="3" />
                <animateMotion
                  dur="14s"
                  begin="-8s"
                  repeatCount="indefinite"
                  rotate="auto"
                  path="M590 0 C 570 112, 620 214, 552 330 S 492 454, 520 520 C 420 650, 318 842, 252 1160"
                />
              </g>
              <g class="road-vehicle road-vehicle-car road-vehicle-big" aria-hidden="true">
                <rect class="vehicle-body" x="-15" y="-6" width="30" height="12" rx="6" />
                <rect class="vehicle-roof" x="-5" y="-4" width="10" height="8" rx="3" />
                <animateMotion
                  dur="15s"
                  begin="-12s"
                  repeatCount="indefinite"
                  rotate="auto"
                  path="M590 0 C 570 112, 620 214, 552 330 S 492 454, 520 520 C 612 650, 696 842, 706 1160"
                />
              </g>
              <circle class="road-dot" data-road-dot cx="590" cy="0" r="10" />
            </svg>
            <div class="road-atmosphere" aria-hidden="true">
              <div class="rail-crossing">
                <span class="rail-line rail-line-top"></span>
                <span class="rail-line rail-line-bottom"></span>
                <div class="rail-train">
                  <span class="train-car train-engine"></span>
                  <span class="train-car"></span>
                  <span class="train-car"></span>
                </div>
              </div>
              <div class="road-traffic-light">
                <span class="traffic-light traffic-light-red"></span>
                <span class="traffic-light traffic-light-yellow"></span>
                <span class="traffic-light traffic-light-green"></span>
              </div>
              <span class="road-sign road-sign-small">wb / ozon</span>
              <span class="road-sign road-sign-big">белый ввоз</span>
            </div>
            <div class="road-choice" data-road-choice-panel>
              <span>Развилка маршрута</span>
              <strong>Что вам нужно?</strong>
              <div class="road-choice-actions">
                <button type="button" data-road-choice-button="small" aria-pressed="false">Малый бизнес</button>
                <button type="button" data-road-choice-button="big" aria-pressed="false">Крупный бизнес</button>
              </div>
            </div>
          </div>
        </div>
      </section>

      <script is:inline>
        window.addEventListener("DOMContentLoaded", () => {
        const routeBoard = document.querySelector(".route-board");
        const stageButtons = document.querySelectorAll("[data-stage]");
        const closeButton = document.querySelector(".route-detail-close");
        const road = document.querySelector("[data-road]");
        const roadTrunk = document.querySelector("[data-road-trunk]");
        const roadBranchSmall = document.querySelector("[data-road-branch-small]");
        const roadBranchBig = document.querySelector("[data-road-branch-big]");
        const roadDot = document.querySelector("[data-road-dot]");
        const roadChoiceButtons = document.querySelectorAll("[data-road-choice-button]");
        const routeTargets = document.querySelectorAll("[data-route-target]");
        const routeReveal = document.querySelector("[data-route-reveal]");
        const roadStartButton = document.querySelector("[data-road-start]");
        const enterpriseFlow = document.querySelector("[data-enterprise-flow]");
        const enterpriseStartButton = document.querySelector("[data-enterprise-start]");
        const enterpriseNextButtons = document.querySelectorAll("[data-enterprise-next]");
        const enterpriseScenes = document.querySelectorAll("[data-enterprise-scene]");
        const enterpriseRoadStage = enterpriseFlow?.querySelector(".enterprise-road-stage");
        const enterpriseRoadSvg = enterpriseFlow?.querySelector(".enterprise-road-svg");
        const enterpriseRoadPath = enterpriseFlow?.querySelector(".enterprise-road-glow");
        const enterpriseStepCount = 4;
        let roadFrame = 0;
        let roadChoice = "none";
        let isRoadAutoScrolling = false;
        let roadTargetProgress = 0;
        let roadRenderedProgress = 0;
        let hasRenderedRoad = false;
        let roadDriveFrame = 0;
        let enterpriseDriveFrame = 0;
        let enterpriseTruckFrame = 0;
        let enterpriseStep = -1;
        const roadForkProgress = 0.58;
        let enterpriseRoadLength = 0;
        const enterpriseEntryProgress = 0.04;
        const enterpriseStepProgress = [0.18, 0.42, 0.64, 0.82];
        const enterpriseExitProgress = 0.988;
        const enterpriseDotFallback = [
          { x: "55%", y: "29%" },
          { x: "68%", y: "58%" },
          { x: "30%", y: "83%" },
          { x: "38%", y: "93%" },
        ];
        const roadLengths = {
          trunk: 0,
          small: 0,
          big: 0,
        };

        const setStage = (stage) => {
          routeBoard?.classList.remove(
            "active-supplier",
            "active-documents",
            "active-handoff",
            "active-dossier",
          );
          routeBoard?.classList.add("has-active", `active-${stage}`);
          stageButtons.forEach((button) => {
            button.classList.toggle("is-selected", button.dataset.stage === stage);
            button.setAttribute("aria-pressed", String(button.dataset.stage === stage));
          });
        };

        stageButtons.forEach((button) => {
          button.setAttribute("aria-pressed", "false");
          button.addEventListener("click", () => setStage(button.dataset.stage));
        });

        closeButton?.addEventListener("click", () => {
          routeBoard?.classList.remove(
            "has-active",
            "active-supplier",
            "active-documents",
            "active-handoff",
            "active-dossier",
          );
          stageButtons.forEach((button) => {
            button.classList.remove("is-selected");
            button.setAttribute("aria-pressed", "false");
          });
        });

        const clamp = (value, min, max) => Math.min(Math.max(value, min), max);
        const lerp = (start, end, amount) => start + (end - start) * amount;

        const syncRoadChoice = (choice, shouldScroll = false) => {
          roadChoice = choice;
          road?.setAttribute("data-road-choice", choice);
          if (choice !== "big") {
            enterpriseFlow?.classList.remove("is-visible");
          }
          roadChoiceButtons.forEach((button) => {
            const isSelected = button.dataset.roadChoiceButton === choice;
            button.classList.toggle("is-selected", isSelected);
            button.setAttribute("aria-pressed", String(isSelected));
          });

          routeTargets.forEach((target) => {
            target.classList.remove("is-route-selected");
          });

          applyRoadState(roadRenderedProgress);

          if (shouldScroll) {
            const target = document.querySelector(`[data-route-target="${choice}"]`);
            const targetY = target
              ? window.scrollY + target.getBoundingClientRect().top - window.innerHeight * 0.58
              : getRoadScrollPoints().arrival;
            animateRoadScroll(targetY, 1750, { targetProgress: 1 });
          }
        };

        roadChoiceButtons.forEach((button) => {
          button.addEventListener("click", () => {
            syncRoadChoice(button.dataset.roadChoiceButton, true);
            requestRoadProgress();
          });
        });

        const getRoadPoint = (progress) => {
          if (!road || !roadTrunk || !roadBranchSmall || !roadBranchBig || !roadDot) return;

          if (!roadLengths.trunk) {
            roadLengths.trunk = roadTrunk.getTotalLength();
            roadLengths.small = roadBranchSmall.getTotalLength();
            roadLengths.big = roadBranchBig.getTotalLength();
          }

          const isPastFork = progress >= roadForkProgress;
          const branch = roadChoice === "big" ? roadBranchBig : roadBranchSmall;
          const branchLength = roadChoice === "big" ? roadLengths.big : roadLengths.small;

          if (!isPastFork || roadChoice === "none") {
            const trunkProgress = clamp(progress / roadForkProgress, 0, 1);
            return roadTrunk.getPointAtLength(roadLengths.trunk * trunkProgress);
          }

          const branchProgress = clamp((progress - roadForkProgress) / (1 - roadForkProgress), 0, 1);
          return branch.getPointAtLength(branchLength * branchProgress);
        };

        const drawRoadProgress = (progress) => {
          const point = getRoadPoint(progress);
          if (!point || !roadDot) return;

          roadDot.setAttribute("cx", String(point.x));
          roadDot.setAttribute("cy", String(point.y));
        };

        const applyRoadState = (progress) => {
          road?.classList.toggle("is-road-active", progress > 0.01 && progress < 0.99);
          road?.classList.toggle("is-choice-visible", progress >= roadForkProgress - 0.01);
          road?.classList.toggle("is-route-arrived", roadChoice !== "none" && progress > 0.94);
          routeReveal?.classList.toggle("is-route-revealed", roadChoice !== "none" && progress > 0.92);

          routeTargets.forEach((target) => {
            target.classList.toggle(
              "is-route-selected",
              roadChoice !== "none" && target.dataset.routeTarget === roadChoice && progress > 0.88,
            );
          });
        };

        const updateRoadProgress = () => {
          if (!road || !roadTrunk || !roadBranchSmall || !roadBranchBig || !roadDot) return;

          if (!hasRenderedRoad) {
            hasRenderedRoad = true;
            drawRoadProgress(roadRenderedProgress);
          }

          applyRoadState(roadRenderedProgress);
        };

        const requestRoadProgress = () => {
          if (roadFrame) return;
          roadFrame = window.requestAnimationFrame(() => {
            roadFrame = 0;
            updateRoadProgress();
          });
        };

        const easeCarDrive = (value) => {
          const eased = value * value * value * (value * (value * 6 - 15) + 10);
          return clamp(eased, 0, 1);
        };

        const getRoadScrollPoints = () => {
          if (!road) return { hero: 0, fork: window.scrollY, arrival: window.scrollY };

          const roadTop = window.scrollY + road.getBoundingClientRect().top;
          const hero = Math.max(0, roadTop - window.innerHeight * 0.84);
          const fork = roadTop + road.offsetHeight * 0.42 - window.innerHeight * 0.48;
          const arrival = roadTop + road.offsetHeight * 0.96 - window.innerHeight * 0.52;
          return { hero, fork, arrival };
        };

        const jumpToScrollPosition = (top) => {
          try {
            window.scrollTo({
              top,
              left: 0,
              behavior: "instant",
            });
          } catch {
            window.scrollTo(0, top);
          }
        };

        const animateRoadScroll = (targetY, duration = 1700, options = {}) => {
          if (isRoadAutoScrolling) return;

          isRoadAutoScrolling = true;
          document.documentElement.classList.add("is-route-scroll-locked");
          roadStartButton?.classList.add("is-driving");
          roadStartButton?.setAttribute("aria-disabled", "true");

          const startY = window.scrollY;
          const distance = targetY - startY;
          const driveStartProgress = roadRenderedProgress;
          const driveEndProgress = options.targetProgress ?? roadTargetProgress;
          const startTime = performance.now();

          if (roadDriveFrame) {
            window.cancelAnimationFrame(roadDriveFrame);
            roadDriveFrame = 0;
          }

          const tick = (time) => {
            const elapsed = clamp((time - startTime) / duration, 0, 1);
            const driveEased = easeCarDrive(elapsed);

            roadRenderedProgress = lerp(driveStartProgress, driveEndProgress, driveEased);
            roadTargetProgress = roadRenderedProgress;
            drawRoadProgress(roadRenderedProgress);
            applyRoadState(roadRenderedProgress);
            jumpToScrollPosition(startY + distance * driveEased);
            requestRoadProgress();

            if (elapsed < 1) {
              roadDriveFrame = window.requestAnimationFrame(tick);
              return;
            }

            roadDriveFrame = 0;
            roadRenderedProgress = driveEndProgress;
            roadTargetProgress = driveEndProgress;
            drawRoadProgress(roadRenderedProgress);
            applyRoadState(roadRenderedProgress);
            isRoadAutoScrolling = false;
            document.documentElement.classList.remove("is-route-scroll-locked");
            roadStartButton?.classList.remove("is-driving");
            roadStartButton?.removeAttribute("aria-disabled");
          };

          roadDriveFrame = window.requestAnimationFrame(tick);
        };

        const getEnterpriseScrollTarget = (step) => {
          const target = enterpriseFlow?.querySelector(`[data-scheme-stop="${step}"]`);
          return target
            ? window.scrollY + target.getBoundingClientRect().top - window.innerHeight * 0.34
            : window.scrollY;
        };

        const getEnterprisePathPosition = (progress, lookAhead = 0.01) => {
          if (!enterpriseFlow || !enterpriseRoadStage || !enterpriseRoadSvg || !enterpriseRoadPath) return false;

          if (!enterpriseRoadLength) {
            enterpriseRoadLength = enterpriseRoadPath.getTotalLength();
          }

          const clampedProgress = clamp(progress, 0, 1);
          const point = enterpriseRoadPath.getPointAtLength(enterpriseRoadLength * clampedProgress);
          const aheadPoint = enterpriseRoadPath.getPointAtLength(
            enterpriseRoadLength * clamp(clampedProgress + lookAhead, 0, 1),
          );
          const stageRect = enterpriseRoadStage.getBoundingClientRect();
          const svgRect = enterpriseRoadSvg.getBoundingClientRect();
          const viewBox = enterpriseRoadSvg.viewBox?.baseVal;
          const viewBoxWidth = viewBox?.width || 1040;
          const viewBoxHeight = viewBox?.height || 2300;
          const x = svgRect.left - stageRect.left + (point.x / viewBoxWidth) * svgRect.width;
          const y = svgRect.top - stageRect.top + (point.y / viewBoxHeight) * svgRect.height;
          const angle = Math.atan2(aheadPoint.y - point.y, aheadPoint.x - point.x) * (180 / Math.PI);

          return { x, y, angle };
        };

        const setEnterpriseDotPoint = (point) => {
          if (!enterpriseFlow || !point) return false;

          enterpriseFlow.style.setProperty("--enterprise-dot-x", `${point.x}px`);
          enterpriseFlow.style.setProperty("--enterprise-dot-y", `${point.y}px`);
          return true;
        };

        const setEnterpriseDotProgress = (progress) => setEnterpriseDotPoint(getEnterprisePathPosition(progress));

        const getEnterpriseStepProgress = (step) => enterpriseStepProgress[step] ?? enterpriseEntryProgress;

        const closeEnterpriseStops = () => {
          if (!enterpriseFlow) return;

          enterpriseFlow.dataset.enterpriseStep = "moving";
          enterpriseScenes.forEach((scene) => {
            scene.classList.remove("is-active");
          });
        };

        const setEnterpriseDotPosition = (step) => {
          const progress = getEnterpriseStepProgress(step);
          if (setEnterpriseDotProgress(progress)) return;

          const point = enterpriseDotFallback[step] ?? { x: "56%", y: "4%" };
          enterpriseFlow?.style.setProperty("--enterprise-dot-x", point.x);
          enterpriseFlow?.style.setProperty("--enterprise-dot-y", point.y);
        };

        const syncEnterpriseStepContent = (step) => {
          if (!enterpriseFlow) return;

          enterpriseFlow.dataset.enterpriseStep = String(step);

          enterpriseScenes.forEach((scene, index) => {
            scene.classList.toggle("is-active", index === step);
          });

          enterpriseNextButtons.forEach((button) => {
            button.textContent = "Дальше";
          });
        };

        const animateEnterpriseScroll = (targetY, duration = 1550, onDone, options = {}) => {
          if (!enterpriseFlow) return;

          document.documentElement.classList.add("is-route-scroll-locked");
          enterpriseFlow.classList.add("is-driving");

          const startY = window.scrollY;
          const distance = targetY - startY;
          const startTime = performance.now();
          const startProgress = options.fromProgress ?? getEnterpriseStepProgress(options.fromStep ?? enterpriseStep);
          const endProgress = options.toProgress ?? getEnterpriseStepProgress(options.toStep ?? enterpriseStep);
          const revealAt = options.revealStep === undefined ? 1 : clamp(1 - 500 / duration, 0, 1);
          let hasRevealed = false;

          if (enterpriseDriveFrame) {
            window.cancelAnimationFrame(enterpriseDriveFrame);
            enterpriseDriveFrame = 0;
          }

          const tick = (time) => {
            const elapsed = clamp((time - startTime) / duration, 0, 1);
            const eased = easeCarDrive(elapsed);

            jumpToScrollPosition(startY + distance * eased);
            setEnterpriseDotProgress(lerp(startProgress, endProgress, eased));

            if (!hasRevealed && options.revealStep !== undefined && elapsed >= revealAt) {
              hasRevealed = true;
              enterpriseStep = options.revealStep;
              enterpriseFlow.classList.add("is-opening");
              syncEnterpriseStepContent(options.revealStep);
            }

            if (elapsed < 1) {
              enterpriseDriveFrame = window.requestAnimationFrame(tick);
              return;
            }

            enterpriseDriveFrame = 0;
            setEnterpriseDotProgress(endProgress);
            onDone?.();
            enterpriseFlow.classList.remove("is-driving");
            enterpriseFlow.classList.remove("is-opening");
            document.documentElement.classList.remove("is-route-scroll-locked");
          };

          enterpriseDriveFrame = window.requestAnimationFrame(tick);
        };

        const setEnterpriseStep = (step, shouldScroll = false) => {
          if (!enterpriseFlow) return;

          enterpriseStep = (step + enterpriseStepCount) % enterpriseStepCount;
          syncEnterpriseStepContent(enterpriseStep);
          setEnterpriseDotPosition(enterpriseStep);

          if (shouldScroll) {
            animateEnterpriseScroll(getEnterpriseScrollTarget(enterpriseStep), 1550, undefined, {
              fromProgress: enterpriseEntryProgress,
              toStep: enterpriseStep,
              revealStep: enterpriseStep,
            });
          }
        };

        const getTruckExitScrollTarget = () => {
          const target = enterpriseFlow?.querySelector(".enterprise-route-warehouse") ?? document.querySelector(".directions-section");
          return target
            ? window.scrollY + target.getBoundingClientRect().top - window.innerHeight * 0.34
            : window.scrollY;
        };

        const animateEnterpriseTruckExit = () => {
          if (!enterpriseFlow || enterpriseFlow.classList.contains("is-driving")) return;

          document.documentElement.classList.add("is-route-scroll-locked");
          enterpriseFlow.classList.add("is-driving", "is-dispatching");
          enterpriseFlow.setAttribute("data-enterprise-target", "exit");

          const startY = window.scrollY;
          const targetY = getTruckExitScrollTarget();
          const distance = targetY - startY;
          const startProgress = getEnterpriseStepProgress(enterpriseStep);
          const roadDuration = 2500;

          if (enterpriseTruckFrame) {
            window.cancelAnimationFrame(enterpriseTruckFrame);
            enterpriseTruckFrame = 0;
          }

          const startTime = performance.now();

          const tick = (time) => {
            const elapsed = clamp((time - startTime) / roadDuration, 0, 1);
            const eased = easeCarDrive(elapsed);

            setEnterpriseDotProgress(lerp(startProgress, enterpriseExitProgress, eased));
            jumpToScrollPosition(startY + distance * eased);

            if (elapsed < 1) {
              enterpriseTruckFrame = window.requestAnimationFrame(tick);
              return;
            }

            enterpriseTruckFrame = 0;
            setEnterpriseDotProgress(enterpriseExitProgress);
            enterpriseFlow.classList.remove("is-driving", "is-dispatching");
            enterpriseFlow.removeAttribute("data-enterprise-target");
            document.documentElement.classList.remove("is-route-scroll-locked");
          };

          enterpriseTruckFrame = window.requestAnimationFrame(tick);
        };

        enterpriseStartButton?.addEventListener("click", () => {
          if (enterpriseFlow?.classList.contains("is-driving")) return;

          enterpriseFlow?.classList.add("is-visible");
          enterpriseFlow?.classList.remove("is-dispatching");
          enterpriseFlow?.removeAttribute("data-enterprise-target");
          enterpriseStep = -1;
          closeEnterpriseStops();
          setEnterpriseDotProgress(enterpriseEntryProgress);
          animateEnterpriseScroll(
            getEnterpriseScrollTarget(0),
            1850,
            () => setEnterpriseStep(0),
            { fromProgress: enterpriseEntryProgress, toStep: 0, revealStep: 0 },
          );
        });

        enterpriseNextButtons.forEach((button) => button.addEventListener("click", () => {
          if (enterpriseFlow?.classList.contains("is-driving")) return;

          if (enterpriseStep === enterpriseStepCount - 1) {
            animateEnterpriseTruckExit();
            return;
          }

          const fromStep = enterpriseStep < 0 ? 0 : enterpriseStep;
          const nextStep = (enterpriseStep + 1) % enterpriseStepCount;
          closeEnterpriseStops();
          enterpriseFlow?.setAttribute("data-enterprise-target", String(nextStep));
          animateEnterpriseScroll(
            getEnterpriseScrollTarget(nextStep),
            1850,
            () => {
              enterpriseFlow?.removeAttribute("data-enterprise-target");
              setEnterpriseStep(nextStep);
            },
            { fromStep, toStep: nextStep, revealStep: nextStep },
          );
        }));

        roadStartButton?.addEventListener("click", () => {
          if (isRoadAutoScrolling) return;

          syncRoadChoice("none");
          roadRenderedProgress = 0;
          roadTargetProgress = 0;
          drawRoadProgress(roadRenderedProgress);
          applyRoadState(roadRenderedProgress);

          const points = getRoadScrollPoints();
          animateRoadScroll(points.fork, 2200, { targetProgress: roadForkProgress });
        });

        updateRoadProgress();
        window.addEventListener("scroll", requestRoadProgress, { passive: true });
        window.addEventListener("resize", () => {
          roadLengths.trunk = 0;
          roadLengths.small = 0;
          roadLengths.big = 0;
          requestRoadProgress();
        });
        });
      </script>

