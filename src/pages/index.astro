    <footer class="site-footer">
      <a class="brand" href="/" aria-label="RWSCargo / РВС Карго">
        <strong><span>RWS</span>Cargo</strong>
        <small>РВС Карго</small>
      </a>
      <p>RWSCargo / РВС Карго: надежные логистические решения для вашего бизнеса с Китаем.</p>
      <nav aria-label="Навигация в подвале">
        <a href="#services">Услуги</a>
        <a href="#delivery">Доставка</a>
        <a href="#process">Как работаем</a>
        <a href="#contacts">Контакты</a>
        <a href="/privacy/">Политика ПДн</a>
        <a href="/personal-data-consent/">Согласие ПДн</a>
      </nav>
      <span>© 2026 RWSCargo / РВС Карго. Не является публичной офертой.</span>
    </footer>
    <script is:inline>
      const leadForm = document.querySelector("[data-lead-form]");
      const calculator = document.querySelector("[data-calculator]");
      const backToTop = document.querySelector("[data-back-to-top]");
      const revealItems = document.querySelectorAll(
        "main > section:not(.hero):not(.metric-strip), .service-card, .delivery-card, .fit-card, .enterprise-card, .route-lane, .scenario-card, .promise-list article, .faq-group, .calculator-form, .calculator-result, .lead-form",
      );

      revealItems.forEach((item) => item.classList.add("reveal-item"));

      if ("IntersectionObserver" in window) {
        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                revealObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -8% 0px" },
        );

        revealItems.forEach((item) => revealObserver.observe(item));
      } else {
        revealItems.forEach((item) => item.classList.add("is-visible"));
      }

      const updateBackToTop = () => {
        backToTop?.classList.toggle("is-visible", window.scrollY > 720);
      };

      updateBackToTop();
      window.addEventListener("scroll", updateBackToTop, { passive: true });

      backToTop?.addEventListener("click", () => {
        window.scrollTo({ top: 0, behavior: "smooth" });
      });

      const formatRub = (value) =>
        new Intl.NumberFormat("ru-RU", {
          style: "currency",
          currency: "RUB",
          maximumFractionDigits: 0,
        }).format(value);

      const calculatorConfig = {
        auto: { rate: 290, min: 28000, term: "10-30 дней" },
        rail: { rate: 220, min: 45000, term: "18-45 дней" },
        air: { rate: 920, min: 38000, term: "5-12 дней" },
      };

      const zoneMultiplier = {
        central: 1,
        regional: 1.16,
        remote: 1.32,
      };

      const optionPrices = {
        inspect: 7000,
        documents: 15000,
        pickup: 9000,
      };

      const updateCalculator = () => {
        if (!calculator) return;

        const formData = new FormData(calculator);
        const weight = Math.max(Number(formData.get("weight")) || 0, 1);
        const volume = Math.max(Number(formData.get("volume")) || 0, 0.1);
        const mode = String(formData.get("mode") || "auto");
        const zone = String(formData.get("zone") || "central");
        const config = calculatorConfig[mode] || calculatorConfig.auto;
        const chargeableWeight = Math.ceil(Math.max(weight, volume * 167));
        const services = Object.keys(optionPrices).filter((key) => formData.has(key));
        const servicesTotal = services.reduce((sum, key) => sum + optionPrices[key], 0);
        const base = Math.max(chargeableWeight * config.rate, config.min);
        const total = (base + servicesTotal) * (zoneMultiplier[zone] || 1);
        const low = Math.round((total * 0.86) / 1000) * 1000;
        const high = Math.round((total * 1.18) / 1000) * 1000;
        const included = ["логистика", ...services.map((key) => {
          if (key === "inspect") return "проверка";
          if (key === "documents") return "документы";
          return "забор";
        })].join(", ");

        document.querySelector("[data-calc-total]").textContent =
          `от ${formatRub(low)} до ${formatRub(high)}`;
        document.querySelector("[data-calc-chargeable]").textContent = `${chargeableWeight} кг`;
        document.querySelector("[data-calc-term]").textContent = config.term;
        document.querySelector("[data-calc-includes]").textContent = included;
      };

      calculator?.addEventListener("input", updateCalculator);
      calculator?.addEventListener("change", updateCalculator);
      updateCalculator();

      leadForm?.addEventListener("submit", (event) => {
        event.preventDefault();

        if (!leadForm.checkValidity()) {
          leadForm.reportValidity();
          return;
        }

        leadForm.classList.add("is-success");
        const button = leadForm.querySelector("button");
        if (button) {
          button.textContent = "Заявка подготовлена";
          button.setAttribute("disabled", "true");
        }
      });
    </script>
